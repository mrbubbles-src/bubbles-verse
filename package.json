{
  "name": "bubbles-verse",
  "version": "0.0.2",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test -- --run",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@bubbles/eslint-config": "workspace:*",
    "@bubbles/typescript-config": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.3",
    "typescript": "5.9.3"
  }
}
