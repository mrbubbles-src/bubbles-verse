    "@wojtekmaj/react-hooks": "^2.0.4",
    "negotiator": "^1.0.0",
    "next": "16.1.6",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.11",
