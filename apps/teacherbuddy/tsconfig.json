{
  "extends": "@bubbles/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@bubbles/theme": ["../../packages/theme/src/index.ts"],
      "@bubbles/ui/fonts": ["../../packages/ui/src/fonts.ts"],
      "@bubbles/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@bubbles/ui/postcss.config": ["../../packages/ui/postcss.config.mjs"],
      "@bubbles/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
