{
  "repository_type": "monorepo",
  "package_manager": "bun@1.3.11",
  "build_orchestrator": "turborepo@2.9.3",
  "node_version": ">=22 <25 (pinned: 24.14.1)",
  "parts": [
    {
      "part_id": "portfolio",
      "name": "portfolio",
      "project_type_id": "web",
      "display_name": "Portfolio",
      "root_path": "apps/portfolio",
      "framework": "Next.js 16.1.6",
      "language": "TypeScript 5.9.3",
      "description": "Developer portfolio with i18n (DE/EN), email contact, CAPTCHA, PDF CV viewer",
      "external_services": ["Resend", "Cloudflare Turnstile", "Vercel"],
      "has_tests": false,
      "has_database": false
    },
    {
      "part_id": "teacherbuddy",
      "name": "teacherbuddy",
      "project_type_id": "web",
      "display_name": "TeacherBuddy",
      "root_path": "apps/teacherbuddy",
      "framework": "Next.js 16.1.6",
      "language": "TypeScript 5.9.3",
      "description": "Classroom tools: student management, quiz builder/player, breakout rooms, projects",
      "external_services": ["Vercel"],
      "has_tests": true,
      "test_framework": "Vitest 4.0 + React Testing Library",
      "has_database": false,
      "persistence": "localStorage"
    },
    {
      "part_id": "the-coding-vault",
      "name": "the-coding-vault",
      "project_type_id": "web",
      "display_name": "The Coding Vault",
      "root_path": "apps/the-coding-vault",
      "framework": "Next.js 16.1.6",
      "language": "TypeScript 5.9.3",
      "description": "CMS/knowledge base with Editor.js, MDX rendering, JWT auth, Cloudinary media",
      "external_services": ["PostgreSQL", "Cloudinary", "Discord", "Vercel"],
      "has_tests": false,
      "has_database": true,
      "database": "PostgreSQL (Drizzle ORM 0.45)"
    },
    {
      "part_id": "ui",
      "name": "@bubbles/ui",
      "project_type_id": "library",
      "display_name": "@bubbles/ui (Design System)",
      "root_path": "packages/ui",
      "framework": "React 19.2.4 + Base UI + shadcn",
      "language": "TypeScript 5.9.3",
      "description": "26 shadcn components, hooks, utilities, global styles (Tailwind v4)",
      "has_tests": false
    },
    {
      "part_id": "eslint-config",
      "name": "@bubbles/eslint-config",
      "project_type_id": "library",
      "display_name": "@bubbles/eslint-config",
      "root_path": "packages/eslint-config",
      "description": "ESLint flat config presets: base, next-js, react-internal",
      "has_tests": false
    },
    {
      "part_id": "typescript-config",
      "name": "@bubbles/typescript-config",
      "project_type_id": "library",
      "display_name": "@bubbles/typescript-config",
      "root_path": "packages/typescript-config",
      "description": "Shared TypeScript profiles: base, nextjs, react-library",
      "has_tests": false
    }
  ],
  "integration_points": [
    {
      "from": "portfolio",
      "to": "@bubbles/ui",
      "type": "package_import",
      "details": "Components, styles, hooks via subpath exports"
    },
    {
      "from": "teacherbuddy",
      "to": "@bubbles/ui",
      "type": "package_import",
      "details": "Components, styles, hooks via subpath exports"
    },
    {
      "from": "the-coding-vault",
      "to": "@bubbles/ui",
      "type": "package_import",
      "details": "Components, styles, hooks via subpath exports"
    },
    {
      "from": "all_apps",
      "to": "@bubbles/eslint-config",
      "type": "dev_config",
      "details": "ESLint presets (next-js profile)"
    },
    {
      "from": "all_workspaces",
      "to": "@bubbles/typescript-config",
      "type": "dev_config",
      "details": "TypeScript compiler profiles"
    }
  ]
}